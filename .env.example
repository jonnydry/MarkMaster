# Copy to .env and fill in values. Validate with: npm run env:check

# PostgreSQL (see docker-compose.yml for local defaults)
DATABASE_URL="postgresql://user:password@localhost:5432/markmaster"

# Auth.js v5 — required for sessions/cookies (generate: openssl rand -base64 32)
AUTH_SECRET=

# App URL — must match how you open the app (used in OAuth redirects)
NEXTAUTH_URL=http://localhost:3000

# X Developer Portal → your app → Keys → OAuth 2.0 Client ID and Client Secret
# User authentication settings: OAuth 2.0
# Callback URL (add exactly): http://localhost:3000/api/auth/callback/twitter
# Scopes: tweet.read, users.read, bookmark.read, offline.access
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Token encryption at rest (generate: openssl rand -hex 32)
ENCRYPTION_KEY=
